package example1;

import java.util.LinkedList;

public class ArrayListExample {
	
	public static void main(String[] args) {
		
		int[] arr = {5,4,2,5,6,45,58};
		
		for(int a : arr) {
			if(a % 2 == 0) {
				System.out.println("Even : "+a);
			}
		}
		
		for(int a : arr) {
			if(a % 2 == 1) {
				System.out.println("Odd : "+a);
			}
		}
		
	}

}
