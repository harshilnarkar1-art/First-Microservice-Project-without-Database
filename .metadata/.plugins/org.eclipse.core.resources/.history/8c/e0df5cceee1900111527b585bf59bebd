package example1;

import java.util.LinkedList;

public class ArrayListExample {
	
	public static void main(String[] args) {
		
		int[] arr = {5,4,2,5,6,45,58};
		
		boolean isSorted = true;
		
		for(int i = 0; i < arr.length; i++) {
			if(arr[i] == arr[i+1]) {
				isSorted = false;
				break;
			}
		}
		
		System.out.println("isSorted : "+isSorted);
	}

}
