package example1;

import java.util.LinkedList;

public class ArrayListExample {
	
	public static void main(String[] args) {
		
		int[] arr = {5,4,2,5,6,45,58};
		
		for(int i = 0; i < arr.length; i++) {
			boolean unique = true;
			for(int j = 0; j < arr.length; j++) {
				if(i != j && arr[i] == arr[j]) {
					unique = false;
					break;
				}
			}
			if(unique) {
				System.out.println(arr[i]);
			}
		}
	}

}
