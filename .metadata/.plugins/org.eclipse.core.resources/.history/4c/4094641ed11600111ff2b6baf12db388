		ArrayList<String> name = new ArrayList<String>();
		
		name.add("Harshil");
		name.add("Pratibha");
		name.add("Rajesh");
		name.add("Sheetal");
		name.add("Shantaram");
		
		
		System.out.println("Enter Your Name : "+sc.nextLine());
		if(sc.equals(name)) {
			name.remove(0);
			System.out.println(name);
			
		}
//		else if(!sc.equals(name)) {
//			System.out.println("Not Found");
//		}
		
		System.out.println(name);
		
		
		
	}

}
