package example1;

import java.util.LinkedList;

public class ArrayListExample {
	
	public static void main(String[] args) {
		
		int[] arr = {5,4,2,5,6,45,58};
		
		int target = 5;
		int count = 0;
		
		for(int i = 0; i < arr.length; i++) {
			if(arr[i] == target) {
				count++;
			}
		}
		System.out.println(count);
	}

}
