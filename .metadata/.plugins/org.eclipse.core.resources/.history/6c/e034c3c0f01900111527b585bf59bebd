package example1;

import java.util.LinkedList;

public class ArrayListExample {
	
	public static void main(String[] args) {
		
		int[] arr = {5,4,2,5,6,45,58};
		
		int first = arr[0];
		
		for(int i = 0; i < arr.length-1; i++) {
			arr[i] = arr[i+1];
		}
		
		arr[arr.length-1] = first;
		
		for(int num : arr) {
			System.out.print(num+" ");
		}
	}

}
